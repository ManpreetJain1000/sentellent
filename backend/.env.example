APP_NAME=sentellent
# Human-readable backend application name.

APP_ENVIRONMENT=development
# Runtime stage for the backend service.

APP_DEBUG=true
# Enables local development debug behavior.

APP_HOST=0.0.0.0
# Host interface the backend binds to.

APP_PORT=8000
# HTTP port exposed by the backend service.

DATABASE_URL=postgresql+psycopg://sentellent_user:sentellent_password@localhost:5432/sentellent
# SQLAlchemy-compatible PostgreSQL connection string.

REDIS_URL=redis://localhost:6379/0
# Redis connection string for session caching.

JWT_SECRET_KEY=
# Secret used to sign backend-issued tokens.

JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
# Lifetime of access tokens in minutes.

GOOGLE_OAUTH_CLIENT_ID=
# Google OAuth client ID used for server-side authorization.

GOOGLE_OAUTH_CLIENT_SECRET=
# Google OAuth client secret used only on the backend.

GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# Backend callback URL registered in Google Cloud.

GROQ_API_KEY=
# API key for the Groq LLM provider.

GROQ_MODEL_NAME=llama-3.3-70b-versatile
# Default Groq model used by the agent.

GROQ_FALLBACK_MODEL_NAME=qwen/qwen3-32b
# First fallback Groq model when the primary model hits rate limits.

GROQ_FALLBACK_MODELS=qwen/qwen3-32b,openai/gpt-oss-120b,qwen/qwen3.6-27b
# Additional Groq models tried in order after the primary and first fallback.
# Optional: add qwen/qwen3-32b variants available on your Groq account.

AGENT_MAX_HISTORY_MESSAGES=8
# Max prior chat turns sent to the LLM per request (lower = fewer tokens).

AGENT_MAX_TOOL_ROUNDS=6
# Max agent tool-call loops per message (lower = fewer tokens).

PGVECTOR_EMBEDDING_DIMENSIONS=384
# Expected embedding size for pgvector storage.

EMBEDDING_MODEL_NAME=hash-v1
# Local embedding provider identifier.

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
# Comma-separated browser origins allowed to call the API.

FRONTEND_URL=http://localhost:5173
# Public frontend URL used for OAuth redirects.

GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar
# Space-separated Google OAuth scopes (Gmail read + Calendar read/write).

TOKEN_ENCRYPTION_KEY=
# Optional key for encrypting stored OAuth tokens at rest.

DEFAULT_TIMEZONE=Asia/Kolkata
# IANA timezone used for scheduling when Google Calendar timezone is unavailable.

CELERY_BROKER_URL=
# Celery broker URL; defaults to REDIS_URL when empty.

CELERY_RESULT_BACKEND=
# Celery result backend URL; defaults to REDIS_URL when empty.

CELERY_TASK_ALWAYS_EAGER=false
# Run Celery tasks inline (useful for tests and local debugging).

SENTRY_DSN=
# Optional Sentry DSN for error tracking (Developer free tier).

RATE_LIMIT_AUTH_PER_MINUTE=10
# Auth route rate limit per IP.

RATE_LIMIT_CHAT_PER_MINUTE=20
# Chat message rate limit per authenticated user.

RATE_LIMIT_INGEST_PER_HOUR=5
# Workspace email ingest rate limit per authenticated user.

EMAIL_INGEST_ASYNC_ENABLED=true
# When true, email fetch enqueues background jobs instead of blocking chat.

S3_UPLOAD_BUCKET_NAME=
# S3 bucket used for uploads or generated assets.
